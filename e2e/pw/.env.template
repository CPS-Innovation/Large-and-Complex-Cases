# Environment URLs
BASE_URL=                          # LCC UI URL
CMS_LOGIN_PAGE=                    # Tactical login URL (/api/tactical/login)
CASE_API_BASE_URL=                 # Case Management API
DDEI_BASE_URL=                     # DDEI API
EGRESS_BASE_URL=                   # Egress API

# Azure AD
TENANT_ID=
CLIENT_ID=

# Credentials (secrets - set in CI/CD or .env.local)
E2E_AD_USER=                       # Azure AD email
E2E_AD_PASSWORD=                   # Azure AD password
CMS_USERNAME=                      # CIN3 username
CMS_PASSWORD=                      # CIN3 password
DDEI_ACCESS_KEY=                   # DDEI function key

# Egress
EGRESS_SERVICE_ACCOUNT_AUTH=       # Base64 service account credentials
EGRESS_TEMPLATE_ID=59a6855307087630eb190282
EGRESS_ADMIN_ROLE_ID=591dab08368b665c9c5c5fe0

# Test Parameters
TEST_FILE_SIZE_MB=100              # Test file size
TEST_FILE_COUNT=1                  # Number of files to upload

# Default mode — required for npm run e2e:existing-case
# By convention the Egress workspace and the connected NetApp folder both
# use the name `existingCaseAutomation`. Provision the pair once per
# environment and point all four DEFAULT_* values at that case.
# Register-case mode is independent: it auto-creates AUTOMATION-TESTING<N>
# workspaces and connects to the `Automation-Testing` NetApp folder.
DEFAULT_WORKSPACE_ID=                # Egress workspace id for existingCaseAutomation
DEFAULT_WORKSPACE_NAME=existingCaseAutomation
DEFAULT_CASE_URN=                    # URN of the case connected to that workspace
DEFAULT_CASE_ID=                     # Numeric case id of the same case

# NetApp teardown + fixture target for default mode. By the same
# default-mode convention this matches DEFAULT_WORKSPACE_NAME. Register-
# case mode uses its own hardcoded folder and ignores this variable.
# The DELETE endpoint is disabled in production (403); leave
# LCC_API_BASE_URL blank for prod-pointing runs.
LCC_API_BASE_URL=                    # LCC backend, e.g. https://fa-lacc-api-dev.azurewebsites.net
NETAPP_OPERATION_NAME=existingCaseAutomation
