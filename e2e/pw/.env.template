# Environment URLs
BASE_URL=                          # LCC UI URL
CMS_LOGIN_PAGE=                    # Tactical login URL (/api/tactical/login)
CASE_API_BASE_URL=                 # Case Management API
DDEI_BASE_URL=                     # DDEI API
EGRESS_BASE_URL=                   # Egress API

# Azure AD
TENANT_ID=
CLIENT_ID=

# Credentials (secrets - set in CI/CD or .env.local)
E2E_AD_USER=                       # Azure AD email
E2E_AD_PASSWORD=                   # Azure AD password
CMS_USERNAME=                      # CIN3 username
CMS_PASSWORD=                      # CIN3 password
DDEI_ACCESS_KEY=                   # DDEI function key

# Egress
EGRESS_SERVICE_ACCOUNT_AUTH=       # Base64 service account credentials
EGRESS_TEMPLATE_ID=59a6855307087630eb190282
EGRESS_ADMIN_ROLE_ID=591dab08368b665c9c5c5fe0

# Test Parameters
TEST_FILE_SIZE_MB=100              # Test file size
TEST_FILE_COUNT=1                  # Number of files to upload

# Default mode — required for npm run e2e:existing-case
# Only needed when running against a pre-existing connected case (default mode).
# Leave blank for full-flow tests that create a new case.
DEFAULT_WORKSPACE_ID=                # Pre-existing Egress workspace ID
DEFAULT_WORKSPACE_NAME=              # Pre-existing Egress workspace name
DEFAULT_CASE_URN=                    # Pre-existing case URN
DEFAULT_CASE_ID=                     # Pre-existing case numeric ID
