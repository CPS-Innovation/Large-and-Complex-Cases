{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "Storage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",
    "SizeConfig__ChunkSizeBytes": "10485760",
    "SizeConfig__BatchSize": "4",
    "SizeConfig__MaxConcurrentPartUploads": "2",
    "EgressOptions__Url": "http://localhost:<port>",
    "EgressOptions__Username": "<username",
    "EgressOptions__Password": "<email>:<password>",
    "EgressOptions__ManagementTimeoutSeconds": "100",
    "EgressOptions__TransferTimeoutSeconds": "300",
    "NetAppOptions__Url": "https://<NetApp URL>/",
    "NetAppOptions__ClusterUrl": "https://<NetApp Cluster URL>/",
    "NetAppOptions__RegionName": "eu-west-1",
    "NetAppOptions__SessionDurationSeconds": "3600",
    "NetAppOptions__S3ServiceUuid": "<Your NetApp S3 service UUID>",
    "NetAppOptions__PepperVersion": "v1",
    "NetAppOptions__RequestTimeoutSeconds": "100",
    "ConnectionStrings__CaseManagementDatastoreConnection": "Your postgres connection string",
    "FileTransfer__PurgeRetention__RetentionDays": "30",
    "FileTransferPurgeRetentionSchedule": "0 0 2 * * *",
    "SizeConfig__MaxOrchestratorRetries": "3",
    "SizeConfig__FolderPreCreateRetryAttempts": "3",
    "SizeConfig__FolderPreCreateFirstRetryIntervalSeconds": "5",
    "SizeConfig__FolderPreCreateBackoffCoefficient": "2.0",
    "ManageMaterialsCleanupSchedule": "0 0 2 * * *",
    "FileTransfer__ManageMaterialsCleanup__MaxAgeHours": "24"
  },
  "Host": {
    "LocalHttpPort": 7072
  }
